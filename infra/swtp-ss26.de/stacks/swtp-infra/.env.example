# === Hoppscotch ===
DATABASE_URL=postgresql://hoppscotch:change-me-hoppscotch@hoppscotch-db:5432/hoppscotch?connect_timeout=300
HOPPSCOTCH_DB_PASSWORD=change-me-hoppscotch
DATA_ENCRYPTION_KEY=change-me-32-char-encryption-key
VITE_BASE_URL=https://restclient.swtp-ss26.de
VITE_SHORTCODE_BASE_URL=https://restclient.swtp-ss26.de
VITE_ADMIN_URL=https://restclient-admin.swtp-ss26.de
VITE_BACKEND_GQL_URL=https://restclient-api.swtp-ss26.de/graphql
VITE_BACKEND_WS_URL=wss://restclient-api.swtp-ss26.de/graphql
